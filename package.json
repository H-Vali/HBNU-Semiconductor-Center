{
  "name": "hbnu-semiconductor-center",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.0.7",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @hbnu/web",
    "dev:api": "npm run dev --workspace @hbnu/api",
    "build": "npm run build --workspace @hbnu/web && npm run build --workspace @hbnu/api",
    "check": "npm run lint --workspaces --if-present",
    "docker:up": "docker compose up --build",
    "db:migrate": "npm run migrate --workspace @hbnu/api"
  },
  "engines": {
    "node": ">=22.13"
  }
}
